      {
        "id": "rpn-overview",
        "anchor": "rpn-overview",
        "title": "What is RPN?",
        "content": "Reverse Polish Notation (RPN) is a postfix notation where operators follow operands. For example, to compute 3 + 4, enter 3, press Enter, enter 4, then press +."
      },
      {
        "id": "rpn-enable",
        "anchor": "rpn-enable",
        "title": "Enabling RPN Mode",
        "content": "Enable RPN mode from Settings > RPN Mode toggle, or from the mode button on the Calculator screen. The stack display appears above the input field when RPN is active."
      },
      {
        "id": "rpn-stack-ops",
        "anchor": "rpn-stack-ops",
        "title": "Stack Operations",
        "content": "Use ENTER to push the current value onto the stack. SWAP exchanges the top two stack elements. DROP removes the top element. CLR clears the entire stack."
      },
      {
        "id": "rpn-example",
        "anchor": "rpn-example",
        "title": "RPN Example",
        "content": "To compute (3 + 4) * 2: enter 3, press ENTER; enter 4, press +; enter 2, press *. The result 14 appears at the top of the stack."
      }
    ]
